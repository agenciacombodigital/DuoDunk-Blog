{
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "https://brerfpcfkyptkzygyzxl.supabase.co/functions/v1/rss-feed"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-posts-nba",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron-scrape-news",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron-process-ai",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/cron-auto-publish",
      "schedule": "*/30 * * * *"
    }
  ]
}