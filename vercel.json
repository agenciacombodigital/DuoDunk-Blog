{
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "https://brerfpcfkyptkzygyzxl.supabase.co/functions/v1/rss-feed"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://brerfpcfkyptkzygyzxl.supabase.co/functions/v1/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-posts-nba",
      "schedule": "30 6 * * *"
    }
  ]
}